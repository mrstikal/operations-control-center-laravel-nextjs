{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:full": "concurrently \"php artisan serve --port=8000\" \"npm --prefix frontend run dev\"",
    "api:dev": "php artisan serve --port=8000",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run start",
    "lint": "npm --prefix frontend run lint",
    "format": "npm --prefix frontend run format",
    "format:check": "npm --prefix frontend run format:check",
    "smoke": "npm --prefix frontend run smoke",
    "test": "npm --prefix frontend run test",
    "test:watch": "npm --prefix frontend run test:watch",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:open": "npm --prefix frontend run test:e2e:open"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
